# INFORMIX Spa — Proxmox Portal Configuration (example)

# Application
APP_ENV=development
DEMO_MODE=false
USE_AWS_SECRETS=false

# Database (solo sviluppo locale)
DB_HOST=db
DB_PORT=5432
DB_NAME=informix_portal
DB_USER=informix_admin
# DB_PASSWORD: non includere segreti in questo file
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# JWT
# JWT_SECRET_KEY: inserisci una stringa lunga e sicura nel tuo .env reale
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY

# Proxmox
# In produzione utilizzare un utente API dedicato con token
PROXMOX_HOST=192.168.1.100
PROXMOX_USER=apiuser@pve!portal-token
PROXMOX_TOKEN_VALUE=00000000-0000-0000-0000-000000000000

# LAN DNS (dominio personalizzato)
LAN_DNS_IP=REPLACE_WITH_DOCKER_HOST_IP

# AWS
AWS_REGION=eu-south-1
AWS_SECRET_NAME=informix/portal/config
# Inserisci il tuo AWS account ID nel .env reale
AWS_ACCOUNT_ID=REPLACE_WITH_AWS_ACCOUNT_ID
# ╔══════════════════════════════════════════════════════╗
# ║  INFORMIX Spa — Proxmox Portal Configuration        ║
# ║  ⚠ NON inserire credenziali sensibili qui!          ║
# ║  I segreti sono gestiti da AWS Secrets Manager       ║
# ╚══════════════════════════════════════════════════════╝

# ─── Application ──────────────────────────────────────
APP_ENV=development
DEMO_MODE=true
USE_AWS_SECRETS=false

# ─── Database (solo sviluppo locale) ─────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=informix_portal
DB_USER=informix_admin
DB_PASSWORD=InformixDev2024!

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-in-production

# ─── Proxmox ─────────────────────────────────────────
PROXMOX_HOST=192.168.1.100
PROXMOX_USER=apiuser@pve!portal-token
PROXMOX_TOKEN_VALUE=your-token-value-here

# ─── LAN DNS (dominio personalizzato) ────────────────
# Imposta l'IP della macchina che ospita Docker, raggiungibile dagli altri device della LAN.
LAN_DNS_IP=10.1.11.57

# ─── AWS ──────────────────────────────────────────────
AWS_REGION=eu-south-1
AWS_SECRET_NAME=informix/portal/config
AWS_ACCOUNT_ID=123456789012
