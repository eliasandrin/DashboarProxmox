# INFORMIX Proxmox Portal Configuration (example)
# Do not put real secrets here. Use .env for local dev or AWS Secrets Manager in prod.

# Application
APP_ENV=development
DEMO_MODE=true
USE_AWS_SECRETS=false

# Database (local dev)
DB_HOST=db
DB_PORT=5432
DB_NAME=informix_portal
DB_USER=informix_admin
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# JWT
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY

# Proxmox
PROXMOX_HOST=192.168.1.100
PROXMOX_USER=apiuser@pve!portal-token
PROXMOX_TOKEN_VALUE=CHANGE_ME_PROXMOX_TOKEN

# LAN DNS (optional)
LAN_DNS_IP=REPLACE_WITH_DOCKER_HOST_IP

# AWS (used in cloud deployments)
AWS_REGION=eu-west-1
AWS_SECRET_NAME=informix/portal/config
AWS_ACCOUNT_ID=REPLACE_WITH_AWS_ACCOUNT_ID
